# ── Server ──────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── PostgreSQL ───────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=student_hub
DB_USER=postgres
DB_PASSWORD=yourpassword

# ── JWT ──────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=7d

# ── File Uploads ─────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=50

# Copy this file to .env and fill in your actual values.
# Never commit .env to version control — it is listed in .gitignore.

PORT=3000

# ── Option A: Individual connection variables (local development) ─────────────
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=your_postgres_username
DB_PASSWORD=your_postgres_password
DB_NAME=campus_crud

# ── Option B: Single connection string (hosted services like Render, Railway) ─
# If DATABASE_URL is set, it takes priority over the individual variables above.
# DATABASE_URL=postgresql://user:password@host:5432/campus_crud

# Set to "true" if your hosted PostgreSQL requires SSL (Render, Heroku, etc.)
DB_SSL=false

# ── CORS ─────────────────────────────────────────────────────────────────────
# Restrict to your frontend's URL in production, e.g.:
# ALLOWED_ORIGIN=https://yoursite.com
ALLOWED_ORIGIN=*

# ── API resource name (default: projects) ────────────────────────────────────
RESOURCE=projects
